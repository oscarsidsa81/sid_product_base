<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sid_location_option_tree" model="ir.ui.view">
        <field name="name">sid.location.option.tree</field>
        <field name="model">sid.location.option</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="location_type"/>
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_sid_location_option_form" model="ir.ui.view">
        <field name="name">sid.location.option.form</field>
        <field name="model">sid.location.option</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="location_type"/>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sid_location_option" model="ir.actions.act_window">
        <field name="name">Sidsa Ubicaciones-Productos</field>
        <field name="res_model">sid.location.option</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="menu_sid_location_option"
        name="Sidsa Ubicaciones-Productos"
        parent="base.menu_administration"
        action="action_sid_location_option"
        sequence="95"
        groups="base.group_system"
    />
</odoo>
